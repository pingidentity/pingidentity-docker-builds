		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "PingDataConsole landing redirect",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var locationHeader = pm.response.headers.get(\"Location\") || pm.response.headers.get(\"location\");",
							"var normalizedLocation = (locationHeader || \"\").replace(/^https?:\\/\\/[^/]+/, \"\");",
							"",
							"pm.test(\"PingDataConsole redirects\", function () {",
							"    pm.response.to.have.status(302);",
							"});",
							"",
							"pm.test(\"PingDataConsole exposes a redirect target\", function () {",
							"    pm.expect(locationHeader).to.exist;",
							"});",
							"",
							"pm.test(\"PingDataConsole redirect target is supported\", function () {",
							"    pm.expect([\"/console/\", \"/console/login\", \"/console/login/\", \"/console/index.html\"]).to.include(normalizedLocation);",
							"});",
							"",
							"if (normalizedLocation === \"/console/\") {",
							"    postman.setNextRequest(\"PingDataConsole routed landing redirect\");",
							"} else if (normalizedLocation === \"/console/login\" || normalizedLocation === \"/console/login/\") {",
							"    postman.setNextRequest(\"PingDataConsole login page\");",
							"} else if (normalizedLocation === \"/console/index.html\") {",
							"    postman.setNextRequest(\"PingDataConsole SPA index page\");",
							"} else {",
							"    postman.setNextRequest(null);",
							"}",
							""
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://{{PD_CONSOLE_PRIVATE_HOSTNAME}}:{{PD_CONSOLE_PRIVATE_PORT_HTTPS}}/console",
					"protocol": "https",
					"host": [
						"{{PD_CONSOLE_PRIVATE_HOSTNAME}}"
					],
					"port": "{{PD_CONSOLE_PRIVATE_PORT_HTTPS}}",
					"path": [
						"console"
					]
				}
			},
			"response": []
		},
